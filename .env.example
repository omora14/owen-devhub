# Google Analytics — replace with your GA4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# EmailJS — create free account at https://www.emailjs.com
# 1. Create a service (Gmail/iCloud) → copy Service ID
# 2. Create an email template → copy Template ID  
# 3. Go to Account → copy Public Key
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
